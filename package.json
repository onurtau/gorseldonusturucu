{
  "name": "gorsel-donusturucu",
  "version": "1.0.0",
  "description": "Profesyonel görsel dönüştürme ve optimizasyon uygulaması",
  "main": "electron/main.js",
  "homepage": ".",
  "scripts": {
    "start": "react-scripts start",
    "start:web": "npx env-cmd -f .env.web react-scripts start",
    "start:electron": "npx env-cmd -f .env.electron react-scripts start",
    "build": "react-scripts build",
    "build:web": "npx env-cmd -f .env.web.production react-scripts build",
    "build:electron": "npx env-cmd -f .env.electron react-scripts build",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run start:electron\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-build": "npm run build:electron && electron-builder",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.98.0",
    "axios": "^1.6.5",
    "bcryptjs": "^3.0.3",
    "color-convert": "^2.0.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "framer-motion": "^10.18.0",
    "lucide-react": "^0.309.0",
    "react": "^18.2.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^6.21.0",
    "sharp": "^0.33.2",
    "tailwindcss": "^3.4.1",
    "uuid": "^9.0.1",
    "zod": "^4.3.6",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "env-cmd": "^10.1.0",
    "postcss": "^8.4.33",
    "react-scripts": "5.0.1",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
