# Supabase Configuration
# Bu dosyayı kopyalayıp .env olarak kaydedin ve kendi değerlerinizi girin

# Supabase Project URL (https://app.supabase.com adresinden alınacak)
REACT_APP_SUPABASE_URL=your_supabase_project_url

# Supabase Anon/Public Key (https://app.supabase.com adresinden alınacak)
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# App Environment
REACT_APP_ENV=development

# OAuth Redirect URLs (production için güncellenecek)
REACT_APP_OAUTH_REDIRECT_URL=http://localhost:3000/auth/callback
